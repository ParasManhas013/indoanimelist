# App
ENVIRONMENT=development
FRONTEND_URL=http://localhost:3000

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/indoalist

# Redis
REDIS_URL=redis://localhost:6379
LEADERBOARD_CACHE_TTL=60

# JWT
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=7
REFRESH_TOKEN_EXPIRE_DAYS=30

# Resend (Email)
RESEND_API_KEY=re_xxxxxxxxxxxx
FROM_EMAIL=noreply@indoalist.com
FROM_NAME=IndoAList

# Cloudflare R2 (Image Storage)
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY=your-r2-access-key
R2_SECRET_KEY=your-r2-secret-key
R2_BUCKET_NAME=indoalist-images
R2_PUBLIC_URL=https://pub-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.dev

# Bayesian Ranking
MIN_VOTES=25

# Admin
ADMIN_API_KEY=replace-with-a-strong-admin-key
